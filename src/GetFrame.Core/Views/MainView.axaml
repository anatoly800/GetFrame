<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GetFrame.Core.ViewModels"
             xmlns:conv="clr-namespace:GetFrame.Core.Converters"
             x:Class="GetFrame.Core.Views.MainView"
             x:DataType="vm:MainWindowViewModel">
  <UserControl.Resources>
    <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,*,Auto" Margin="10">

    <Border Grid.Row="0" Classes="RoundedBorder">
      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" >
        <Button Grid.Column="0" Command="{Binding OpenCommand}" Margin="4" ToolTip.Tip="Open a video file">
          <Image Source="{Binding OpenIconSource}" Width="20" Height="20"/>
        </Button>
        <TextBox Grid.Column="1" Text="{Binding FrameNumberText, UpdateSourceTrigger=PropertyChanged}" Watermark="Frame number" Margin="4" ToolTip.Tip="Enter the frame number to preview and export" />
        <Button Grid.Column="2" Command="{Binding SettingsCommand}" Margin="4" ToolTip.Tip="Open application settings">
          <Image Source="{Binding SettingsIconSource}" Width="20" Height="20"/>
        </Button>
        <Button Grid.Column="3" Command="{Binding SaveCommand}" Margin="4" ToolTip.Tip="Save the current frame as a PNG image">
          <Image Source="{Binding SaveIconSource}" Width="20" Height="20"/>
        </Button>
        <Button Grid.Column="4" Command="{Binding OpenPngFolderCommand}" Margin="4" ToolTip.Tip="Open the folder where PNG files are saved">
          <Image Source="{Binding OpenPngFolderIconSource}" Width="20" Height="20"/>
        </Button>
      </Grid>
    </Border>

    <Border Grid.Row="1" Classes="RoundedBorder">
      <Viewbox StretchDirection="DownOnly" Stretch="Uniform">
        <Image Source="{Binding PreviewImage}" />
      </Viewbox>
    </Border>

    <Border Grid.Row="2" Classes="RoundedBorder" Classes.ErrorBorder="{Binding HasError}">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="5">
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsVisible="{Binding IsBusy}" ToolTip.Tip="Stop the current operation">
            <Button.Styles>
                <Style Selector="Button">
                <Setter Property="Background" Value="#2E7D32" />
                <Style.Animations>
                    <Animation Duration="0:0:1.2" IterationCount="INFINITE" PlaybackDirection="Alternate">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#2E7D32" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#66BB6A" />
                    </KeyFrame>
                    </Animation>
                </Style.Animations>
                </Style>
            </Button.Styles>
            </Button>
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>
    </Border>

  </Grid>
</UserControl>
